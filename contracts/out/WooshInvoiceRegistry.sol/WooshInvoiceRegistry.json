id\",\"type\":\"bytes32\"},{\"indexed\":true,\"internalType\":\"address\",\"name\":\"payee\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"address\",\"name\":\"payer\",\"type\":\"address\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"}],\"name\":\"InvoicePaid\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"salt\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"memo\",\"type\":\"string\"}],\"name\":\"create\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"id\",\"type\":\"bytes32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"id\",\"type\":\"bytes32\"}],\"name\":\"getInvoice\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"payee\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"paid\",\"type\":\"bool\"},{\"internalType\":\"address\",\"name\":\"payer\",\"type\":\"address\"},{\"internalType\":\"string\",\"name\":\"memo\",\"type\":\"string\"},{\"internalType\":\"uint64\",\"name\":\"createdAt\",\"type\":\"uint64\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"creator\",\"type\":\"address\"}],\"name\":\"getInvoiceIds\",\"outputs\":[{\"internalType\":\"bytes32[]\",\"name\":\"\",\"type\":\"bytes32[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"creator\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"salt\",\"type\":\"uint256\"}],\"name\":\"invoiceId\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"stateMutability\":\"pure\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"id\",\"type\":\"bytes32\"}],\"name\":\"pay\",\"outputs\":[],\"stateMutability\":\"payable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"title\":\"WooshInvoiceRegistry\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"create(uint256,uint256,string)\":{\"notice\":\"Register a payment request. Stores amount + memo under the caller's id.\"},\"getInvoice(bytes32)\":{\"notice\":\"Read an invoice. payee == 0x0 means it doesn't exist.\"},\"getInvoiceIds(address)\":{\"notice\":\"All invoice ids created by `creator`, newest last. For the client's         \\\"my requests\\\" list \\u2014 read straight from chain, no off-chain store.\"},\"invoiceId(address,uint256)\":{\"notice\":\"Deterministic id for a creator's request. Same (creator, salt) => same id.\"},\"pay(bytes32)\":{\"notice\":\"Pay a registered request. msg.value must equal the stored amount.\"}},\"notice\":\"On-chain payment requests (\\\"invoices\\\"). The creator registers the invoice         on-chain \\u2014 amount, memo and payee are STORED here, set by the creator and         immutable. The shared link carries only the invoice id; the payer reads the         authoritative amount/memo from this contract, so nothing in the URL can be         tampered with. pay() enforces the exact stored amount and forwards it to the         payee. The contract custodies nothing between create and pay.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/WooshInvoiceRegistry.sol\":\"WooshInvoiceRegistry\"},\"evmVersion\":\"osaka\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[]},\"sources\":{\"src/WooshInvoiceRegistry.sol\":{\"keccak256\":\"0x3d98f8f382117eb9414036a12329db1e4ddd06938b1145182e41498b57f2f6f0\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://dff9d7fbf9cdda1f93bc9fbe4bafdfba9e5ee021c5b4ad498889d305b855b393\",\"dweb:/ipfs/QmXw78GuxppxNJdgGZHwumKZpewkga3VPfKvT5guGr3yww\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.35+commit.47b9dedd"},"language":"Solidity","out