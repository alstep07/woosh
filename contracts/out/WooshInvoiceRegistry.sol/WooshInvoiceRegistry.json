ool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"payee\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"nonce\",\"type\":\"uint256\"}],\"name\":\"pay\",\"outputs\":[],\"stateMutability\":\"payable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"title\":\"WooshInvoiceRegistry\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"invoiceId(address,uint256,uint256)\":{\"notice\":\"Deterministic id for a request. Same terms => same id.\"},\"paid(bytes32)\":{\"notice\":\"True once the request with this id has been paid in full.\"},\"pay(address,uint256,uint256)\":{\"notice\":\"Pay a request. Reverts unless msg.value exactly equals the requested         amount, and unless the request hasn't already been settled.\"}},\"notice\":\"On-chain payment requests (\\\"invoices\\\"). A request is identified by         id = keccak256(abi.encode(payee, amount, nonce)) \\u2014 derived from its own         terms. Paying a different amount yields a different id, so it can never         mark the real request paid. The contract custodies nothing: it forwards         the exact native amount to the payee and records that the request was         settled, emitting a canonical event. Status (`paid[id]`) is the source of         truth \\u2014 no off-chain bookkeeping, no Blockscout amount-matching heuristics.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/WooshInvoiceRegistry.sol\":\"WooshInvoiceRegistry\"},\"evmVersion\":\"osaka\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[]},\"sources\":{\"src/WooshInvoiceRegistry.sol\":{\"keccak256\":\"0x81f615227b31bd8f947bbd0f3f5e628d50ed37e31673b152cbbc2b9c0f280596\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://49642b26e06b2fe3c1e5b5769aa0f6a0e8505460da0258e4fcd149fac9942ebb\",\"dweb:/