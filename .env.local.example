# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Arc Network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_FAUCET_URL=https://faucet.circle.com/

# WalletConnect (get a project ID at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Circle User-Controlled Wallets
# API key: console.circle.com → Project Settings
CIRCLE_API_KEY=
# App ID: console.circle.com → Wallets → User Controlled → Configurator
NEXT_PUBLIC_CIRCLE_APP_ID=

# Smart contracts (deploy via Foundry, then paste the address)
NEXT_PUBLIC_SLUG_REGISTRY_ADDRESS=
NEXT_PUBLIC_INVOICE_REGISTRY_ADDRESS=

# Woosh Agent chat (OpenRouter — openrouter.ai/keys)
OPENROUTER_API_KEY=
# Model to use, e.g. anthropic/claude-3-5-sonnet or anthropic/claude-opus-4-6
ANTHROPIC_MODEL=anthropic/claude-3-5-sonnet
