# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Arc Network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_FAUCET_URL=https://faucet.circle.com/

# WalletConnect (get a project ID at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Circle User-Controlled Wallets
# API key: console.circle.com → Project Settings
CIRCLE_API_KEY=
# App ID: console.circle.com → Wallets → User Controlled → Configurator
NEXT_PUBLIC_CIRCLE_APP_ID=

# Smart contracts (deploy via Foundry, then paste the address)
NEXT_PUBLIC_SLUG_REGISTRY_ADDRESS=
NEXT_PUBLIC_INVOICE_REGISTRY_ADDRESS=
NEXT_PUBLIC_STRATEGY_REGISTRY_ADDRESS=
NEXT_PUBLIC_SAVINGS_VAULT_ADDRESS=      # WooshSavingsVault on Arc (savings vault, V3.2)

# Swap / DCA tokens (Arc Testnet). EURC defaults to the known testnet address if unset.
NEXT_PUBLIC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
# cirBTC testnet address — confirm from Arc docs/faucet before enabling cirBTC DCA
NEXT_PUBLIC_CIRBTC_ADDRESS=

# Circle Developer-Controlled Wallets (autonomous strategy executor — server only)
# Generate + register the entity secret in Circle Console; NEVER expose to the client.
CIRCLE_ENTITY_SECRET=
# Executor wallet — fill in AFTER calling POST /api/admin/provision-executor once.
# Then call WooshStrategyRegistry.setExecutor(EXECUTOR_ADDRESS) and fund it with USDC.
EXECUTOR_WALLET_ID=
EXECUTOR_ADDRESS=
# Synthra SynRoute API, the swap rail on Arc testnet (server only, required for all swaps).
# Get a key from Synthra; used by /v1/quote and /v1/swap.
SYNTHRA_API_KEY=

# Strategy executor (Vercel Cron). Shared secret the cron + admin routes check.
CRON_SECRET=

# Woosh Agent chat (OpenRouter — openrouter.ai/keys)
OPENROUTER_API_KEY=
# Model to use. Default: anthropic/claude-sonnet-5. Avoid small models (haiku),
# they follow the 9-tool system prompt poorly.
ANTHROPIC_MODEL=anthropic/claude-sonnet-5
